{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Records",
  "type": "object",
  "properties": {
    "records": {
      "type": "array",
      "description": "RDF Record fixture descriptions",
      "items": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "description": "Filename (of RDF Turtle file) in data/records/ directory (the file can use the persistentUrlVar value)"
          },
          "repository": {
            "type": "string",
            "description": "Target repository for the RDF data",
            "enum": ["main", "drafts"],
            "default": "main"
          },
          "uri": {
            "type": "string",
            "description": "URI for the RDF resource, can include replacement variable for persistent URL (you can use the persistentUrlVar value)"
          }
        },
        "required": ["file", "repository", "uri"],
        "additionalProperties": false
      }
    },
    "persistentUrlVar": {
      "type": "string",
      "description": "Replacement variable for persistent URL",
      "default": "{{ persistentUrl }}"
    }
  },
  "required": ["records", "persistentUrlVar"],
  "additionalProperties": false
}
